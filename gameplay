class Board:
    def __init__(self, board_size):
        self.size = board_size
        self.grid = []
        self.ship_board = []
        self.guess_board = []
        for x in range(self.size): #makes the grid of ~
            row = ['~']* self.size
            self.grid.append(row)
        for y in range(self.size):
            row = ['~']* self.size
            self.guess_board.append(row)
        for j in range(self.size):
            row = ['~']* self.size
            self.ship_board.append(row)
        self.small_used = False
        self.large_used = False

    def display_ships(self): #copies of the boards
        for row in self.ship_board:
            new_row = " ".join(row)
            print(new_row)

    def display_guesses(self):
        for row in self.guess_board:
            new_row = " ".join(row)
            print(new_row)

    def ship_place(self):
        direction = input('horizontal or vertical:')
        location_row = int(input('Row #:'))
        location_col = int(input('Column #:'))
        size = input('large or small:')
        if size == 'small': #make sure that you dont reuse the same size ship
            if self.small_used:
                print('small ship already used, restart game')
                return
            size = 3
            self.small_used = True
        elif size == 'large':
            if self.large_used:
                print('large ship already used, restart game')
                return
            size = 5
            self.large_used = True

        if location_row >= self.size or location_col >= self.size or location_row < 0 or location_col < 0: #makes it so that you have to stay inside the grid
            print('Invalid input')
            return
        if direction == 'horizontal' and location_col + size >= self.size: #makes sure the ships stay in bounds
            print('Invalid input')
            return
        if direction == 'vertical' and location_row + size >= self.size:
            print('Invalid input')
            return
        if direction not in ['horizontal', 'vertical']: #makes it so that you cant put anything other than horizontal or vertical
            print('Invalid input')
            return

        if direction == 'horizontal':
            for i in range(location_col, location_col + size):
                if self.ship_board[location_row][i] != '~': #goes across the columns to go through each to make sure they are all ~, this is so ships dont overlap
                    return
            for i in range(location_col, location_col + size):
                row = location_row
                col = i
                self.ship_board[row][col] = '^' #goes in and adds all of the ships

        if direction == 'vertical':
            for i in range(location_row, location_row+ size):
                if self.ship_board[i][location_col] != '~':
                    return
            for i in range(location_row, location_row + size):
                row = i
                col = location_col
                self.ship_board[row][col] = '^'
        print('Ship placed')
        self.display_ships()
        
    def mask(self, location_row, location_col):
        if location_row >= self.size or location_col >= self.size or location_row < 0 or location_col < 0:
            print('Invalid input')
            return "invalid"
        if self.ship_board[location_row][location_col] == '^':
            self.guess_board[location_row][location_col] = 'X'
            return "hit"
        self.guess_board[location_row][location_col] = 'O'
        return "miss"



